# Vault roots inside the container, separated by your platform's path separator.
HVM_VAULT_ROOTS=/vault/root-1:/vault/root-2:/vault/root-3

# Optional named vault mapping. When set, this takes precedence over HVM_VAULT_ROOTS.
# Format: name:/container/path,name2:/container/path2
HVM_VAULTS=root-1:/vault/root-1,root-2:/vault/root-2,root-3:/vault/root-3

# Host directories to mount into the compose container. Defaults in docker-compose.yml
# point at ./fixtures/sample-vault so `docker compose up --build` works locally.
HVM_HOST_VAULT_1=/absolute/path/to/vault-1
HVM_HOST_VAULT_2=/absolute/path/to/vault-2
HVM_HOST_VAULT_3=/absolute/path/to/vault-3

# Persistent local data for the memory service.
HVM_DATA_DIR=/data
HVM_QDRANT_URL=http://qdrant:6333
HVM_QDRANT_PATH=/data/qdrant
HVM_MANIFEST_PATH=/data/manifest.json

# Automatic sync cadence.
HVM_SYNC_POLL_SECONDS=60
HVM_SYNC_FULL_RESYNC_SECONDS=21600

# Qdrant collection and embedding settings.
HVM_COLLECTION_NAME=hermes_vault_memory
HVM_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
HVM_CHUNK_SIZE=1600
HVM_CHUNK_OVERLAP=200

# Optional bearer token for HTTP/MCP access. If set, send:
# Authorization: Bearer <token>
HVM_AUTH_TOKEN=

# Disabled by default. Enables sync/rebuild MCP tools that mutate the vector index.
HVM_ENABLE_MUTATION_TOOLS=false
